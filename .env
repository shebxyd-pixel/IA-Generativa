
# Configuración de Kofu v0.7
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434


# Usar LLM local (true/false)
USE_LOCAL_LLM=true

# Modelo LLM a usar (opciones: mistralai/Mistral-7B-Instruct-v0.3, meta-llama/Llama-3.1-8B-Instruct, etc.
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Google API Keys (opcional, para búsqueda mejorada)
GOOGLE_API_KEY=
GOOGLE_CX=
